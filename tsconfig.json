{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "module": "esnext", // Enable ES module syntax
    "moduleResolution": "node", // Use Node.js-style module resolution
    "target": "es2020", // Optional: Match your React Native version
    "esModuleInterop": true, // Recommended for compatibility
    "baseUrl": "./src",
    "paths": {
      "app/*": ["app/*"],
      "pages/*": ["pages/*"],
      "widgets/*": ["widgets/*"],
      "features/*": ["features/*"],
      "entities/*": ["entities/*"],
      "shared/*": ["shared/*"],
      "typeRoots": [
        "node_modules/@types",
        "src/types"
      ],
      "types": [
        "react-native",
        "redux-persist"
      ]
    }
  },
  "include": [
    "src/**/*",
    "src/types/**/*"
  ]
}
